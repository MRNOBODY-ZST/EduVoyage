# Optional overrides for local Docker Compose or CI image tagging.
#
# The checked-in docker-compose.yml already contains safe local-development
# defaults. Do not reuse these values in production.

EDUVOYAGE_JWT_SECRET=replace-with-at-least-32-random-bytes
MONGODB_URI=mongodb://root:secret@mongodb:27017/eduvoyage?authSource=admin
SPRING_MONGODB_URI=mongodb://root:secret@mongodb:27017/eduvoyage?authSource=admin
SPRING_DATA_MONGODB_URI=mongodb://root:secret@mongodb:27017/eduvoyage?authSource=admin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=eduvoyage
